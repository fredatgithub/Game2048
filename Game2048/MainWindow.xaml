<Window x:Class="Game2048.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="2048"
        Height="720"
        Width="540"
        MinHeight="680"
        MinWidth="520"
        Background="#FFFAF8EF"
        KeyDown="Window_KeyDown">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="54"
                       FontWeight="Bold"
                       Foreground="#FF776E65"
                       Text="2048" />
            <TextBlock Margin="0,8,0,0"
                       FontSize="17"
                       Foreground="#FF776E65"
                       TextWrapping="Wrap">
                Utilisez les flèches du clavier pour déplacer et fusionner les tuiles.
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,24,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Border Background="#FFBBADA0"
                        CornerRadius="8"
                        Padding="16,10"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#FFEEE4DA"
                                   Text="SCORE" />
                        <TextBlock x:Name="ScoreTextBlock"
                                   HorizontalAlignment="Center"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="0" />
                    </StackPanel>
                </Border>

                <Border Background="#FFBBADA0"
                        CornerRadius="8"
                        Padding="16,10">
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#FFEEE4DA"
                                   Text="MEILLEUR" />
                        <TextBlock x:Name="BestScoreTextBlock"
                                   HorizontalAlignment="Center"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <Button x:Name="NewGameButton"
                        Width="130"
                        Height="44"
                        Click="NewGameButton_Click"
                        Background="#FFF59D3D"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Content="Nouvelle partie" />
                <TextBlock x:Name="StatusTextBlock"
                           Margin="0,10,0,0"
                           Width="130"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#FF776E65"
                           Text="Fusionnez jusqu'à 2048 !" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="#FFBBADA0"
                CornerRadius="12"
                Padding="12">
            <UniformGrid Rows="4" Columns="4">
                <Border x:Name="CellBorder00" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText00" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder01" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText01" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder02" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText02" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder03" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText03" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder10" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText10" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder11" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText11" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder12" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText12" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder13" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText13" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder20" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText20" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder21" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText21" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder22" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText22" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder23" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText23" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder30" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText30" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder31" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText31" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder32" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText32" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <Border x:Name="CellBorder33" Margin="6" CornerRadius="8" Background="#FFCDC1B4">
                    <TextBlock x:Name="CellText33" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
            </UniformGrid>
        </Border>
    </Grid>
</Window>
